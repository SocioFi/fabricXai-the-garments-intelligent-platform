# ============================================
# FabricXAI Garments Intelligent Platform
# Environment Variables Configuration
# ============================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env.local (for local development)
# 2. Fill in the values below with your actual credentials
# 3. Never commit .env.local to version control
#
# ============================================

# ============================================
# Supabase Configuration (Frontend)
# ============================================
# These variables are used by the Vite frontend application
# If you want to use environment variables instead of hardcoded values,
# you'll need to update src/utils/supabase/info.tsx to read from these.

# Your Supabase project URL
# Format: https://YOUR_PROJECT_ID.supabase.co
# Find in: Supabase Dashboard â†’ Settings â†’ API â†’ Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your Supabase anonymous/public key
# This is safe to expose in the frontend (it's public)
# Find in: Supabase Dashboard â†’ Settings â†’ API â†’ anon public key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Supabase project ID (if needed separately)
# Format: YOUR_PROJECT_ID
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# ============================================
# Development Server Configuration
# ============================================
# Port for the Vite development server (default: 3000)
# VITE_PORT=3000

# ============================================
# Application Configuration
# ============================================
# Environment name (development, staging, production)
# VITE_APP_ENV=development

# Application base URL (for local development)
# VITE_APP_URL=http://localhost:3000

# ============================================
# Feature Flags (Optional)
# ============================================
# Enable/disable features for different environments
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_DEBUG_MODE=false

# ============================================
# Supabase Edge Functions (Backend)
# ============================================
# NOTE: These are used by Supabase Edge Functions, NOT the frontend
# Set these in: Supabase Dashboard â†’ Edge Functions â†’ Settings â†’ Environment Variables
# Do NOT set these in your .env.local file - they won't work there
#
# SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# Notes:
# ============================================
# 1. Currently, the app uses hardcoded Supabase values in:
#    src/utils/supabase/info.tsx
#
# 2. To use environment variables instead:
#    - Update src/utils/supabase/info.tsx to read from import.meta.env
#    - Uncomment and fill in the VITE_SUPABASE_* variables above
#
# 3. For Vercel deployment:
#    - Set these variables in Vercel Dashboard â†’ Settings â†’ Environment Variables
#    - Make sure to set them for Production, Preview, and Development environments
#
# 4. For Supabase Edge Functions:
#    - Set environment variables in Supabase Dashboard (not in .env file)
#    - Go to: Supabase Dashboard â†’ Edge Functions â†’ Settings â†’ Environment Variables
